{
  "default_generate_summary": true,
  "source_defaults": {
    "ignore": [
      ".DS_Store"
    ]
  },
  "sources": [
    {
      "name": "wp-motor-usage",
      "repo": "https://github.com/wp-labs/wp-motor.git",
      "ref": "main",
      "checkout_subdir": "docs/usage",
      "local_path": "../../dev/wparse/wp-motor/docs/usage",
      "ignore": [
        "README.md",
        "01-cli",
        "01-cli/*",
        "01-cli/**"
      ],
      "mappings": [
        {
          "from": "zh",
          "to": "docs-zh/10-user"
        },
        {
          "from": "en",
          "to": "docs-en/10-user"
        }
      ]
    },
    {
      "name": "wp-lang-docs",
      "repo": "https://github.com/wp-labs/wp-lang.git",
      "ref": "main",
      "checkout_subdir": "docs",
      "local_path": "../wp-lang/docs",
      "mappings": [
        {
          "from": "zh",
          "to": "docs-zh/10-user/03-wpl"
        },
        {
          "from": "en",
          "to": "docs-en/10-user/03-wpl"
        }
      ]
    },
    {
      "name": "warp-parse-use",
      "local_path": "../../dev/wparse/warp-parse/docs/use",
      "rewrite_cross_language_links": true,
      "ignore": [
        "tools",
        "tools/*",
        "tools/**"
      ],
      "replace_text": {
        "zh": [
          {
            "from": "# 使用文档",
            "to": "# CLI 使用手册"
          }
        ],
        "en": [
          {
            "from": "# Usage Docs",
            "to": "# CLI Usage Guide"
          }
        ]
      },
      "mappings": [
        {
          "from": "zh",
          "to": "docs-zh/10-user/01-cli",
          "clean": true
        },
        {
          "from": "en",
          "to": "docs-en/10-user/01-cli",
          "clean": true
        }
      ]
    }
  ]
}
